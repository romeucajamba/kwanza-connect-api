# KwanzaConnect — variáveis de ambiente
# Copie este ficheiro para .env e preencha os valores reais.
# NUNCA faça commit do ficheiro .env com valores reais!

# ── Django ──────────────────────────────────────────────────────────
SECRET_KEY=your-very-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de dados (PostgreSQL) ───────────────────────────────────────
DB_NAME=kwanzaconnect
DB_USER=postgres
DB_PASSWORD=your_db_password_here
DB_HOST=localhost
DB_PORT=5432

# ── Redis ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── JWT ──────────────────────────────────────────────────────────────
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ── Email (SMTP) ──────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
DEFAULT_FROM_EMAIL=KwanzaConnect <noreply@kwanzaconnect.ao>

# ── API de Câmbio (open.er-api.com — gratuita, sem registo) ───────────
EXCHANGE_RATE_BASE_URL=https://open.er-api.com/v6/latest
# Deixa vazio se usar open.er-api.com (não precisa de chave)
EXCHANGE_RATE_API_KEY=