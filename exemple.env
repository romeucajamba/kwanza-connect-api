# ==================== Segurança ====================
SECRET_KEY=

DEBUG=
ALLOWED_HOSTS=

# ==================== Banco de Dados ====================
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=                  # ← muda para "localhost" se não estiver usando Docker
DB_PORT=

# ==================== Redis ====================
REDIS_URL=     # ← muda para "redis://localhost:6379/0" se não for Docker

# ==================== Opcionais mas recomendadas ====================
# CORS (se estiveres usando django-cors-headers)
CORS_ALLOW_ALL_ORIGINS=
# ou
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SimpleJWT (se quiseres configurar tempo de expiração do token)
ACCESS_TOKEN_LIFETIME_MINUTES=
REFRESH_TOKEN_LIFETIME_DAYS=

# Email (caso uses envio de email no futuro)
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USE_TLS=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Outras úteis
DJANGO_SUPERUSER_EMAIL=
DJANGO_SUPERUSER_PASSWORD=

SECRET_KEY=